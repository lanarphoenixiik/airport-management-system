{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Запуск сервера",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/manage.py",
            "args": ["runserver", "0.0.0.0:8000"],
            "django": true,
            "autoReload": {
                "enable": true
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Django: Миграции",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/manage.py",
            "args": ["makemigrations"],
            "django": true,
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Django: Применить миграции",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/manage.py",
            "args": ["migrate"],
            "django": true,
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Django: Создать суперпользователя",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/manage.py",
            "args": ["createsuperuser"],
            "django": true,
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        }
    ]
}